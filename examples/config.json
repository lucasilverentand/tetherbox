{
  "server": {
    "host": "127.0.0.1",
    "port": 8787,
    "publicUrl": "https://tetherbox.example.com",
    "operatorTokenEnv": "TETHERBOX_OPERATOR_TOKEN"
  },
  "state": {
    "path": "state/daemon.sqlite",
    "worktreeRetentionDays": 7
  },
  "queue": {
    "concurrency": 1,
    "shutdownGraceMs": 30000,
    "approvalTimeoutMs": 86400000
  },
  "linear": {
    "webhookSecretEnv": "LINEAR_WEBHOOK_SECRET",
    "apiKeyEnv": "LINEAR_API_KEY",
    "repositorySuggestionMinConfidence": 0.2,
    "oauthClientIdEnv": "LINEAR_CLIENT_ID",
    "oauthClientSecretEnv": "LINEAR_CLIENT_SECRET",
    "oauthScopes": ["read", "write", "app:assignable", "app:mentionable"]
  },
  "codex": {
    "bin": "codex",
    "model": "gpt-5.5",
    "sandbox": "workspace-write",
    "minSupportedVersion": "0.135.0",
    "appServerStartupTimeoutMs": 30000,
    "turnTimeoutMs": 1800000
  },
  "git": {
    "signingKeyPath": "~/.ssh/codex_signing_key"
  },
  "repos": [
    {
      "linearTeams": ["ENG"],
      "github": "lucasilverentand/example",
      "localPath": "/Users/luca/Developer/example",
      "defaultBase": "main",
      "testCommands": ["bun test"]
    }
  ],
  "policies": [
    {
      "name": "docs-auto",
      "labels": ["docs"],
      "repos": ["lucasilverentand/example"],
      "teams": ["ENG"],
      "decision": "allow_auto",
      "sandbox": "workspace-write"
    },
    {
      "name": "security-plan-only",
      "labels": ["security"],
      "priorities": [2, 3],
      "decision": "allow_plan_only",
      "sandbox": "workspace-write"
    },
    {
      "name": "infra-needs-approval",
      "paths": ["infra/**", "terraform/**", "k8s/**"],
      "decision": "require_approval"
    }
  ]
}
